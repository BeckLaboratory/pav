include README.md
include LICENSE
include CHANGELOG.md
include CODE_OF_CONDUCT.md
include CONTRIBUTING.md
include pyproject.toml
include tox.toml

graft tests
graft src/pav3/data
graft src/pav3/workflow

prune local
prune dist
prune docs/build
prune .tox
prune .venv
prune .pytest_cache
prune .ruff_cache
prune .idea
prune .claude

global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
global-exclude *.so
